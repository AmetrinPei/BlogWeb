# Copy to deploy/.env (or export). Never commit real secrets.
# Activate stack: docker compose -f deploy/docker-compose.yml --env-file deploy/.env up -d --build

# Required (prod / Compose)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
DB_PASSWORD=change-me-strong-db-password
ADMIN_PASSWORD=change-me-strong-admin-password
# Must be https public origin (prod profile rejects localhost)
BLOG_SITE_BASE_URL=https://blog.example.com

# Optional
BLOG_CORS_ALLOWED_ORIGIN_PATTERNS=
BLOG_PUBLIC_REGISTRATION_ENABLED=false
# Login failure limiter (Slice-A): max failures per IP/username in window; <=0 disables
BLOG_LOGIN_MAX_FAILURES=5
BLOG_LOGIN_WINDOW_SECONDS=900
SPRING_JPA_HIBERNATE_DDL_AUTO=update
HTTP_PORT=80
HTTPS_PORT=443

# Dev-only overrides (local spring-boot:run without Compose)
# BLOG_UPLOAD_DIR=./data/uploads
# BLOG_COMMENT_RATE_LIMIT=5
# BLOG_SITE_FEED_LIMIT=20
